generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model footballer_fixtures {
  id                     Int       @id @default(autoincrement())
  footballer_id          Int
  fixture_id             Int
  is_home                Boolean?
  difficulty             Int?
  code                   Int?      @unique
  team_h                 Int?
  team_h_score           Int?
  team_a                 Int?
  team_a_score           Int?
  event                  Int?
  finished               Boolean?
  minutes                Int?
  provisional_start_time Boolean?
  kickoff_time           DateTime? @db.Timestamp(6)
  event_name             String?   @db.VarChar(255)

  footballers footballers @relation(fields: [footballer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([footballer_id, fixture_id])
}

model footballers {
  id                                   Int                   @id @unique
  team_id                              Int?
  web_name                             String?               @db.VarChar(255)
  code                                 Int?                  @unique
  first_name                           String?               @db.VarChar(255)
  second_name                          String?               @db.VarChar(255)
  team_code                            Int?
  now_cost                             Int?
  selected_by_percent                  String?               @db.VarChar(10)
  goals_scored                         Int?
  assists                              Int?
  bonus                                Int?
  bps                                  Int?
  total_points                         Int?
  status                               String?               @db.VarChar(10)
  news                                 String?
  expected_goals                       String?               @db.VarChar(10)
  expected_assists                     String?               @db.VarChar(10)
  expected_goal_involvements           String?               @db.VarChar(10)
  expected_goals_conceded              String?               @db.VarChar(10)
  expected_goals_per_90                Float?
  expected_assists_per_90              Float?
  expected_goal_involvements_per_90    Float?
  expected_goals_conceded_per_90       Float?
  goals_conceded_per_90                Float?
  element_type                         Int?
  can_transact                         Boolean?
  can_select                           Boolean?
  chance_of_playing_next_round         Int?
  chance_of_playing_this_round         Int?
  cost_change_event                    Int?
  cost_change_event_fall               Int?
  cost_change_start                    Int?
  cost_change_start_fall               Int?
  dreamteam_count                      Int?
  ep_next                              String?               @db.VarChar(10)
  ep_this                              String?               @db.VarChar(10)
  event_points                         Int?
  form                                 String?               @db.VarChar(10)
  in_dreamteam                         Boolean?
  news_added                           DateTime?             @db.Timestamp(6)
  photo                                String?               @db.VarChar(255)
  points_per_game                      String?               @db.VarChar(10)
  removed                              Boolean?
  special                              Boolean?
  squad_number                         Int?
  team                                 Int?
  transfers_in                         Int?
  transfers_in_event                   Int?
  transfers_out                        Int?
  transfers_out_event                  Int?
  value_form                           String?               @db.VarChar(10)
  value_season                         String?               @db.VarChar(10)
  region                               Int?
  team_join_date                       DateTime?             @db.Date
  minutes                              Int?
  clean_sheets                         Int?
  goals_conceded                       Int?
  own_goals                            Int?
  penalties_saved                      Int?
  penalties_missed                     Int?
  yellow_cards                         Int?
  red_cards                            Int?
  saves                                Int?
  influence                            String?               @db.VarChar(10)
  creativity                           String?               @db.VarChar(10)
  threat                               String?               @db.VarChar(10)
  ict_index                            String?               @db.VarChar(10)
  starts                               Int?
  influence_rank                       Int?
  influence_rank_type                  Int?
  creativity_rank                      Int?
  creativity_rank_type                 Int?
  threat_rank                          Int?
  threat_rank_type                     Int?
  ict_index_rank                       Int?
  ict_index_rank_type                  Int?
  corners_and_indirect_freekicks_order Int?
  corners_and_indirect_freekicks_text  String?
  direct_freekicks_order               Int?
  direct_freekicks_text                String?
  penalties_order                      Int?
  penalties_text                       String?
  saves_per_90                         Float?
  now_cost_rank                        Int?
  now_cost_rank_type                   Int?
  form_rank                            Int?
  form_rank_type                       Int?
  points_per_game_rank                 Int?
  points_per_game_rank_type            Int?
  selected_rank                        Int?
  selected_rank_type                   Int?
  starts_per_90                        Float?
  clean_sheets_per_90                  Float?
  defensive_contribution               Int?
  defensive_contribution_per_90        Float?
  footballer_fixtures                  footballer_fixtures[]
  teams                                teams?                @relation(fields: [team_id], references: [id], onUpdate: NoAction, map: "fk_team")
  history                              history[]
}

model history {
  opponent_team              Int
  total_points               Int
  was_home                   Boolean
  kickoff_time               DateTime
  team_h_score               Int?
  team_a_score               Int?
  round                      Int
  modified                   Boolean
  minutes                    Int
  goals_scored               Int
  assists                    Int
  clean_sheets               Int
  goals_conceded             Int
  own_goals                  Int
  penalties_saved            Int
  penalties_missed           Int
  yellow_cards               Int
  red_cards                  Int
  saves                      Int
  bonus                      Int
  bps                        Int
  influence                  String
  creativity                 String
  threat                     String
  ict_index                  String
  starts                     Int
  expected_goals             String
  expected_assists           String
  expected_goal_involvements String
  expected_goals_conceded    String
  value                      Int
  transfers_balance          Int
  selected                   Int
  transfers_in               Int
  transfers_out              Int
  fixture_id                 Int
  footballer_id              Int
  defensive_contribution     Int?
  footballer                 footballers @relation(fields: [footballer_id], references: [id], onDelete: Cascade)

  @@id([footballer_id, fixture_id])
  @@index([footballer_id, round])
}

model teams {
  id                    Int           @id @default(autoincrement())
  code                  Int?          @unique
  name                  String?       @db.VarChar(255)
  short_name            String?       @db.VarChar(10)
  strength              Int?
  strength_overall_home Int?
  strength_overall_away Int?
  strength_attack_home  Int?
  strength_attack_away  Int?
  strength_defence_home Int?
  strength_defence_away Int?
  played                Int?
  points                Int?
  position              Int?
  win                   Int?
  draw                  Int?
  loss                  Int?
  form                  String?       @db.VarChar(10)
  team_division         Int?
  unavailable           Boolean?
  pulse_id              Int?          @unique
  footballers           footballers[]

  team_history team_history[]
}

model team_history {
  id             Int   @id @default(autoincrement())
  team_id        Int
  round          Int
  teamXGC        Float
  teamXGS        Float
  goals          Int
  goals_conceded Int

  team teams @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([team_id, round])
}

model app_metadata {
  key   String @id @db.VarChar(100)
  value String @db.VarChar(500)

  @@map("app_metadata")
}

model events {
  id                        Int     @id @unique
  name                      String  @db.VarChar(255)
  average_entry_score       Int
  finished                  Boolean
  data_checked              Boolean
  highest_scoring_entry     Int?
  deadline_time_epoch       Int
  deadline_time_game_offset Int
  highest_score             Int
  is_previous               Boolean
  is_current                Boolean
  is_next                   Boolean
  cup_leagues_created       Boolean
  h2h_ko_matches_created    Boolean
  can_enter                 Boolean
  can_manage                Boolean
  released                  Boolean
  ranked_count              Int
  most_selected             Int
  most_transferred_in       Int
  top_element               Int
  transfers_made            Int
  most_captained            Int?
  most_vice_captained       Int?
  chip_plays                Json?

  @@map("events")
}

model manager_summary {
  entry_id             Int                  @id
  overall_rank         Int?
  total_points         Int?
  stratum              Int // 1=A (top 10k), 2=B (10k–100k), 3=C (100k–end-of-tail, dynamic)
  last_checked_gw      Int?
  // True once we've successfully fetched and persisted this manager's full
  // transfer history into manager_transfers at least once. Gates the
  // populateManagers loop so we don't refetch entry/{id}/transfers/ on
  // every cron pass — only on the first visit. Re-set to false on a fetch
  // failure so the next pass retries.
  has_transfer_history Boolean              @default(false)
  has_chip_history     Boolean              @default(false)
  last_updated         DateTime             @updatedAt
  history              manager_history[]
  picks                manager_picks[]
  cumulative           manager_cumulative[]

  @@index([stratum])
}

model manager_history {
  entry_id             Int
  gw                   Int
  points               Int // net GW points: event_total minus event_transfers_cost
  event_transfers      Int? // count of transfers made in this GW (nullable for pre-migration rows)
  event_transfers_cost Int? // -4 hits cost in this GW (nullable for legacy rows pre-Phase 2 migration)
  points_on_bench      Int? // bench points in this GW (nullable for legacy rows)
  active_chip          String?         @db.VarChar(20) // wildcard | freehit | bboost | 3xc | manager
  manager              manager_summary @relation(fields: [entry_id], references: [entry_id], onDelete: Cascade)

  @@id([entry_id, gw])
  @@index([gw])
}

model manager_picks {
  entry_id             Int
  gw                   Int
  captain_element      Int? // footballer id with multiplier 2 or 3 (TC)
  vice_captain_element Int? // backup captain (footballer id)
  captain_multiplier   Int? // 2 = standard captain, 3 = triple captain, 0 = captain benched
  active_chip          String?         @db.VarChar(20) // wildcard | freehit | bboost | 3xc | manager
  manager              manager_summary @relation(fields: [entry_id], references: [entry_id], onDelete: Cascade)

  @@id([entry_id, gw])
  @@index([gw])
  @@index([captain_element])
}

// Full XV per (entry_id, gw) for users who have hit the team-impact endpoint.
// Lazy-populated only on demand — we don't backfill the sample. The FPL
// `multiplier` field is the post-finalised value (0 benched / 1 starter / 2
// captain / 3 triple captain), already accounting for autosubs and bench
// boost, so downstream code can treat it as ground truth.
model manager_pick_elements {
  entry_id   Int
  gw         Int
  element_id Int
  position   Int // 1..15 (1..11 = starting, 12..15 = bench order)
  multiplier Int // 0/1/2/3 — final, post-autosub, post-chip
  is_captain Boolean
  is_vice    Boolean
  fetched_at DateTime @default(now())

  @@id([entry_id, gw, element_id])
  @@index([entry_id, gw])
  @@index([gw, element_id])
}

// Per-(entry_id, gw) running totals up to and including that GW.
// Maintained by populateManagers.processEntry on every visit; backfilled
// once via backfillManagerCumulative.ts.
//
// Lets stratumCounts (getRangeRank.ts), computeRankPerPoint
// (getTeamImpact.ts) and stratum_gw_running_stats (rebuilt from this table
// at populate time) compute manager-side range stats as
//   cumulative[end_gw] − cumulative[start_gw − 1]
// — two indexed lookups per entry instead of GROUP BY over the full
// manager_history scan. With this in place we use the full sample
// (no SAMPLE_DIVISOR_S3) at populate-rebuild time; per-request range-rank
// queries still sample stratum 3 to bound DISTINCT-ON sort size.
//
// Semantic invariant: emit one row per (entry_id, gw) where manager_history
// has a row for that pair — no synthetic anchor rows, no rows for GWs the
// entry didn't participate in. The DISTINCT ON / LEFT JOIN query pattern
// handles late-joiners and pre-range fall-back via COALESCE.
//
// stratum is denormalised from manager_summary so the hot query needs no
// join. Keep it in sync: every processEntry rebuild rewrites it along with
// the cumulative columns.
//
// chip_*_h1 / chip_*_h2 split: each FPL chip can be played at most twice
// per season — once before the second-half boundary (CHIP_HALVES_BOUNDARY),
// once after. Two booleans per chip let any (start, end) range answer
// "did the user play this chip in the range" via XOR of the c_end and
// c_start halves; a single boolean would mis-detect ranges that contain
// the second play but not the first.
model manager_cumulative {
  entry_id                 Int
  gw                       Int
  cumulative_points        Int // SUM(history.points)              over [1..gw], net of hits
  cumulative_transfers     Int     @default(0) // SUM(event_transfers)
  cumulative_hits_cost     Int     @default(0) // SUM(event_transfers_cost) — divide by 4 for hits count
  cumulative_bench         Int     @default(0) // SUM(points_on_bench)
  cumulative_captain_bonus Int     @default(0) // SUM(captain_pts × (multiplier − 1))
  gws_played               Int     @default(0) // COUNT(*) — for avg_gw_score over a range
  chip_wildcard_h1         Boolean @default(false) // wildcard played in [1..min(gw, CHIP_HALVES_BOUNDARY)]
  chip_wildcard_h2         Boolean @default(false) // wildcard played in (CHIP_HALVES_BOUNDARY..gw]
  chip_freehit_h1          Boolean @default(false)
  chip_freehit_h2          Boolean @default(false)
  chip_bboost_h1           Boolean @default(false)
  chip_bboost_h2           Boolean @default(false)
  has_transfers            Boolean @default(false) // BOOL_OR(event_transfers IS NOT NULL)      — coverage gate
  has_hits                 Boolean @default(false) // BOOL_OR(event_transfers_cost IS NOT NULL) — coverage gate
  has_bench                Boolean @default(false) // BOOL_OR(points_on_bench IS NOT NULL)      — coverage gate
  // Running count of GWs in [1..gw] where the manager has a row in
  // manager_picks. Range delta (cum[end] − cum[start−1]) gives the count
  // of GWs in [start..end] with picks ingested; equals end−start+1 iff
  // the manager has full picks coverage in the range. Lets
  // sampleCaptainAggregate gate to complete-coverage managers without a
  // per-request COUNT(DISTINCT mp.gw) over manager_picks.
  picks_count_cum          Int     @default(0)
  stratum                  Int // denormalised from manager_summary

  manager manager_summary @relation(fields: [entry_id], references: [entry_id], onDelete: Cascade)

  @@id([entry_id, gw])
  @@index([stratum, gw]) // c_start (range-rank): WHERE stratum=X AND gw<Y is a contiguous range
  // c_end for stratumCounts, computeRankPerPoint and the stratum_gw_running_stats
  // rebuild: DISTINCT ON (entry_id) ORDER BY entry_id, gw DESC over a stratum
  // partition, plus the GROUP BY (stratum, gw) at populate time. Without this
  // index PG picks the primary key (entry_id, gw) and post-filters stratum,
  // scanning the full table and Incremental-Sorting 12M+ rows.
  @@index([stratum, entry_id, gw(sort: Desc)])
  // Read-model rebuilds group by exact end GW, then join the start anchor
  // via the primary key. This index keeps the end-side scan bounded by GW.
  @@index([gw, stratum, entry_id])
}

// One row per FPL transfer the manager has ever made (filtered to a range
// at query time via gw). Sourced from `entry/{id}/transfers/`. Populated
// opportunistically when the user queries their own /transfers or /comparison
// endpoints; sample-wide transfer-log enrichment is maintained by
// populateManagers, with MANAGER_INGEST_SAMPLE_TRANSFERS available as a
// rate-limit kill switch.
//
// Used by:
//   - getManagerTransfers (per-user view, joins to history for points)
//   - getManagerComparison.sample_avg_pts_per_transfer (aggregated across
//     stratum, range-conditional on gw and end_gw — can't live as a
//     cumulative because the per-transfer points window depends on the
//     query's end_gw).
model manager_transfers {
  entry_id    Int
  gw          Int
  in_element  Int
  out_element Int
  in_cost     Int
  out_cost    Int
  fetched_at  DateTime @default(now())

  @@id([entry_id, gw, in_element, out_element])
  @@index([entry_id, gw])
  @@index([gw])
}

// Per-(stratum, gw, captain_element, captain_multiplier) pick counts.
// Truncated and rebuilt at the end of each populateManagers run as a single
// GROUP-BY over manager_picks ⨝ manager_summary. Tiny table (~3 strata × 38
// GWs × ~50 distinct captains × ~3 multipliers ≈ <17k rows total) — fits in
// shared_buffers and replaces the per-request GROUP BY in
// fetchCaptainRatesInStratum (getTeamImpact.ts). Sample-side captain/chip
// comparison stats are hidden unless a dedicated historical picks coverage
// model is added.
model stratum_captain_picks_gw {
  stratum            Int
  gw                 Int
  captain_element    Int
  captain_multiplier Int // 0 = captain benched, 2 = standard captain, 3 = triple captain
  picks              Int // count of (entry, gw) rows in stratum with this combo
  last_rebuilt       DateTime @updatedAt

  @@id([stratum, gw, captain_element, captain_multiplier])
  @@index([stratum, gw])
}

// Per-(rank band, gw, player) exposure from sampled managers' full XVs.
// `effective_multiplier_sum / sample_size` is LiveFPL-style EO: it counts
// normal starters as 1, captains as 2, triple captains as 3, bench boosts as
// 1, and ordinary bench players as 0. `squad_picks / sample_size` is kept for
// display as ownership, but rank attribution uses effective multiplier EO.
model rank_band_player_exposure_gw {
  rank_band                Int
  gw                       Int
  element_id               Int
  sample_size              Int
  squad_picks              Int
  active_picks             Int
  effective_multiplier_sum Int
  last_rebuilt             DateTime @updatedAt

  @@id([rank_band, gw, element_id])
  @@index([rank_band, gw])
}

// Per-(stratum, gw) running aggregate stats across the full sample. Each row
// is a snapshot at the end of GW N: sum of every active manager's
// cumulative_X at that GW, plus the count of managers in the snapshot.
//
// Range queries `[s, e]` collapse to two-row lookups: subtract the row at
// gw=s-1 from the row at gw=e (treating gw=0 as zeros for ranges starting
// at GW 1). Replaces the heavy DISTINCT ON over manager_cumulative that
// `sampleStratumAggregates` was running per request.
//
// Refreshed at the end of every `populateManagers` run via
// `rebuildStratumGwRunningStats` (a single GROUP BY (stratum, gw) over
// manager_cumulative), or out-of-band via `backfillStratumGwRunningStats`.
//
// 3 strata × 38 GWs = 114 rows, ~150 bytes each — fits in a single buffer
// page.
model stratum_gw_running_stats {
  stratum               Int
  gw                    Int
  // Population at this gw — count of managers in the stratum with a
  // manager_cumulative row at this GW. Use as the divisor when computing
  // range-averages: avg = (sum_at(e) − sum_at(s−1)) / sample_size_at_e.
  sample_size           Int
  // Running sums (across all sampled managers in the stratum, of their
  // cumulative_X value at this GW). Range total for [s,e] = sum_at(e) −
  // sum_at(s−1).
  sum_cum_points        BigInt
  sum_cum_transfers     BigInt
  sum_cum_hits_cost     BigInt
  sum_cum_bench         BigInt
  sum_cum_captain_bonus BigInt
  sum_gws_played        BigInt
  // Coverage counts — count of managers whose has_X flag is true at this
  // GW. Lets the read path gate display when too few sampled managers
  // have data in the range (mirrors gateOnCoverage in getManagerComparison).
  count_with_transfers  Int
  count_with_hits       Int
  count_with_bench      Int
  count_with_chips      Int      @default(0)
  // Cumulative chip plays through this GW, split by season half. Range
  // chip-rate for [s,e] = (cum_played_at_e − cum_played_at_s−1) /
  // sample_size_at_e. Two halves so a range that spans the boundary picks
  // up either play correctly.
  cum_wildcards_h1      Int
  cum_wildcards_h2      Int
  cum_freehits_h1       Int
  cum_freehits_h2       Int
  cum_bboosts_h1        Int
  cum_bboosts_h2        Int
  last_rebuilt          DateTime @updatedAt

  @@id([stratum, gw])
}

// Histogram of manager range totals by stratum and GW range. Rebuilt from
// manager_cumulative after populateManagers updates the sampled managers.
// Hot reads use this for range-rank and team-impact rank-density estimates:
// a request only sums a few score buckets instead of DISTINCT-sorting every
// sampled manager in the range.
model manager_range_score_buckets {
  stratum      Int
  start_gw     Int
  end_gw       Int
  range_total  Int
  managers     Int
  last_rebuilt DateTime @updatedAt

  @@id([stratum, start_gw, end_gw, range_total])
  @@index([start_gw, end_gw, stratum, range_total])
}
