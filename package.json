{
  "name": "fpl-trends-api",
  "version": "1.0.0",
  "description": "API for the FPL Trends Application. Uses official FPL API.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "build": "npx tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "populate": "cross-env NODE_ENV=development tsx src/database/populateDatabase.ts",
    "migrate": "npx prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clickhouse/client": "^1.10.0",
    "@prisma/client": "^6.2.1",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "csv-parser": "^3.1.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "tsc": "^2.0.4",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.6",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
