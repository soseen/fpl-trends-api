{
  "name": "fpl-trends-api",
  "version": "1.0.0",
  "description": "API for the FPL Trends Application. Uses official FPL API.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "build": "prisma generate && tsc",
    "bootstrap": "prisma generate && tsc && npm run migrate && npm run populate",
    "deploy": "git pull && npm install && npm run build && npm run migrate && pm2 restart fpl-trends-api && (npm run kill-populate || true)",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "populate": "tsx src/database/populateDatabase.ts",
    "populate-managers": "tsx src/database/populateManagers.ts",
    "backfill-picks": "tsx src/database/backfillPicks.ts",
    "backfill-comparison-picks": "tsx src/database/backfillComparisonPicks.ts",
    "backfill-cumulative": "tsx src/database/backfillManagerCumulative.ts",
    "backfill-manager-chips": "tsx src/database/backfillManagerChips.ts",
    "backfill-manager-transfers": "tsx src/database/backfillManagerTransfers.ts",
    "backfill-stratum-range-xfer-avg": "tsx src/database/backfillStratumRangeXferAvg.ts",
    "kill-populate": "tsx src/database/killPopulate.ts",
    "rebuild-manager-read-models": "tsx src/database/rebuildManagerReadModels.ts",
    "reset-manager-analytics": "tsx src/database/resetManagerAnalytics.ts",
    "check-local-state": "tsx src/database/checkLocalState.ts",
    "reset-season": "tsx src/database/resetSeason.ts",
    "migrate": "npx prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "axios": "^1.7.9",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.8",
    "@types/pg": "^8.11.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.15.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  },
  "engines": {
    "node": ">=22.x"
  }
}
